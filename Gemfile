source "https://rubygems.org"

# On utilise la version 4 de Jekyll pour plus de modernité
gem "jekyll", "~> 4.4.1"

# Les plugins nécessaires pour Minimal Mistakes et GitHub
group :jekyll_plugins do
  gem "jekyll-remote-theme"
  gem "jekyll-include-cache"
  gem "jekyll-seo-tag"
  gem "jekyll-sitemap"
  gem "jekyll-feed"
  gem "jekyll-gist"
end

# Pour éviter les erreurs sur Windows/Mac
gem "webrick", "~> 1.8"